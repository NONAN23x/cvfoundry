    {"sourceId": "education", "type": "education", "priority": 60, "rewrite": "none", "selection": {"mode": "all", "entries": {"min": 1, "preferred": 1, "max": 3}}},
    {"sourceId": "technical-skills", "type": "skills", "priority": 80, "rewrite": "none", "selection": {"mode": "all", "entries": {"min": 1, "preferred": 4, "max": 8}, "itemsPerEntry": {"min": 3, "preferred": 5, "max": 10}, "maximumReplacementsPerCategory": 2}}
