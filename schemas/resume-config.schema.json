{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cvfoundry.local/schemas/resume-rules-toml-v4.schema.json",
  "title": "CvFoundry resume.toml parsed rules",
  "type": "object",
  "required": ["version", "theme", "document", "sections"],
  "properties": {
    "version": {"const": 4},
    "theme": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "document": {
      "type": "object",
      "required": ["paper", "target_pages", "max_pages"],
      "properties": {
        "paper": {"enum": ["A4", "LETTER", "a4", "letter"]},
        "target_pages": {"enum": [1, 2]},
        "max_pages": {"enum": [1, 2]}
      },
      "additionalProperties": false
    },
    "header": {
      "type": "object",
      "properties": {
        "contact": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
      },
      "additionalProperties": false
    },
    "quality": {
      "type": "object",
      "properties": {
        "contact_lines": {"type": "integer", "minimum": 1},
        "bottom_whitespace_min_mm": {"type": "number", "minimum": 0},
        "bottom_whitespace_max_mm": {"type": "number", "minimum": 0},
        "intermediate_page_whitespace_max_mm": {"type": "number", "minimum": 0}
      },
      "additionalProperties": false
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "kind"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "kind": {
            "enum": [
              "summary",
              "timeline",
              "portfolio",
              "publications",
              "credentials",
              "bullets",
              "education",
              "skills"
            ]
          },
          "priority": {"type": "integer", "minimum": 0, "maximum": 100},
          "mode": {"enum": ["all", "ranked", "explicit", "ordered"]},
          "rewrite": {"enum": ["none", "source-bounded"]},
          "entries": {"$ref": "#/$defs/pageBudget"},
          "bullets": {"$ref": "#/$defs/pageBudget"},
          "items_per_category": {"$ref": "#/$defs/pageBudget"},
          "replacement_limit": {"type": "integer", "minimum": 0},
          "lines": {"type": "integer", "minimum": 1},
          "bullet_lines": {"type": "integer", "minimum": 1},
          "skill_row_lines": {"type": "integer", "minimum": 1},
          "required": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
          "excluded": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "pageBudget": {
      "type": "object",
      "required": ["one_page", "two_page"],
      "properties": {
        "one_page": {"type": "integer", "minimum": 0},
        "two_page": {"type": "integer", "minimum": 0},
        "minimum": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
