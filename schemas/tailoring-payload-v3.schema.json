{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jobs-tailoring.local/schemas/tailoring-payload-v3.schema.json",
  "title": "Jobs Tailoring Agent Payload v3",
  "type": "object",
  "required": ["schemaVersion", "jobTitle", "summary", "sections"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {"const": 3},
    "jobTitle": {"type": "string", "minLength": 1},
    "summary": {
      "type": "object",
      "required": ["text", "sourceIds"],
      "properties": {
        "text": {"type": "string", "minLength": 1},
        "sourceIds": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true}
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sourceId", "items"],
        "properties": {
          "sourceId": {"type": "string"},
          "items": {"type": "array", "items": {"type": "object"}}
        }
      }
    }
  }
}
